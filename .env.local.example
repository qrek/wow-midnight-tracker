# ─── WarcraftLogs API ────────────────────────────────────────────────────────
# Crée un client sur : https://www.warcraftlogs.com/api/clients/
WCL_CLIENT_ID=your_wcl_client_id
WCL_CLIENT_SECRET=your_wcl_client_secret

# ─── Blizzard Battle.net API ─────────────────────────────────────────────────
# Crée un client sur : https://develop.battle.net/access/clients
BLIZZARD_CLIENT_ID=your_blizzard_client_id
BLIZZARD_CLIENT_SECRET=your_blizzard_client_secret
BLIZZARD_REGION=eu

# ─── Config Guilde ───────────────────────────────────────────────────────────
# Ces variables sont exposées côté client (NEXT_PUBLIC_)
NEXT_PUBLIC_GUILD_NAME=VoidCovenant
NEXT_PUBLIC_GUILD_REALM=kirin-tor
NEXT_PUBLIC_GUILD_REGION=eu
NEXT_PUBLIC_GUILD_DISPLAY_NAME=Void Covenant
